generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum ListingType {
  SELL
  RENT
}

enum ItemCondition {
  LIKE_NEW
  GOOD
  FAIR
  NEEDS_REPAIR
}

enum ItemStatus {
  ACTIVE
  SOLD
  RENTED
  EXPIRED
  REMOVED
}

// ─── Auth.js (NextAuth v5) Models ────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hash — null for OAuth-only users
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // App relations
  items         Item[]
  wishlist      Wishlist[]
  sentMessages  Message[]      @relation("SentMessages")
  conversations Conversation[] @relation("ConversationMembers")
  notifications Notification[]
}

// ─── Notifications ───────────────────────────────────

enum NotificationType {
  MESSAGE
  SYSTEM
  ORDER
  MODERATION
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(SYSTEM)
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ──────────────────────────────────────

model Category {
  id     String  @id @default(cuid())
  slug   String  @unique
  nameTh String
  nameEn String
  emoji  String?
  items  Item[]
}

model Item {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  price       Float
  emoji       String?
  color       String?
  listingType ListingType   @default(SELL)
  condition   ItemCondition @default(GOOD)
  status      ItemStatus    @default(ACTIVE)
  negotiable  Boolean       @default(false)
  shippable   Boolean       @default(false)
  location    String?
  contact     String?
  rating      Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images        ItemImage[]
  wishlists     Wishlist[]
  conversations Conversation[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([listingType])
  @@index([createdAt])
}

model ItemImage {
  id     String  @id @default(cuid())
  url    String
  isMain Boolean @default(false)
  order  Int     @default(0)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemId   String
  item     Item      @relation(fields: [itemId], references: [id])
  members  User[]    @relation("ConversationMembers")
  messages Message[]

  @@index([itemId])
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}
