generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum VerificationStatus {
  UNVERIFIED   // default — has not submitted
  PENDING      // submitted, awaiting admin review
  APPROVED     // identity confirmed, may sell
  REJECTED     // rejected — can resubmit
  SUSPENDED    // was approved, later revoked
}

enum PsuIdType {
  STUDENT  // 10-digit student ID
  STAFF    // 5-digit staff ID
}

enum ListingType {
  SELL
  RENT
}

enum ItemCondition {
  LIKE_NEW
  GOOD
  FAIR
  NEEDS_REPAIR
}

enum DeliveryMethod {
  SHIPPING
  MEETUP
}

enum PaymentMethod {
  ESCROW
  COD
}

enum ItemStatus {
  ACTIVE
  SOLD
  RENTED
  EXPIRED
  REMOVED
  PENDING
  APPROVED
  REJECTED
  UNAVAILABLE
}

// ─── Auth.js (NextAuth v5) Models ────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hash — null for OAuth-only users
  role          Role      @default(STUDENT)
  trustScore    Int       @default(100)
  walletBalance Float     @default(1000) // mock starting balance for testing
  escrowBalance Float     @default(0)    // funds held pending order completion
  isBanned      Boolean   @default(false)
  bannedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // KYC / Seller Verification
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  psuIdNumber         String?            @unique  // set only after APPROVED
  psuIdType           PsuIdType?
  verifiedAt          DateTime?

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // App relations
  items         Item[]
  wishlist      Wishlist[]
  sentMessages  Message[]      @relation("SentMessages")
  conversations Conversation[] @relation("ConversationMembers")
  notifications Notification[]

  // Trust system
  buyerTransactions  Transaction[] @relation("BuyerTransactions")
  sellerTransactions Transaction[] @relation("SellerTransactions")
  reviewsGiven       Review[]      @relation("ReviewsGiven")
  reviewsReceived    Review[]      @relation("ReviewsReceived")

  // Escrow system
  escrowOrdersBuying  EscrowOrder[] @relation("EscrowBuyer")
  escrowOrdersSelling EscrowOrder[] @relation("EscrowSeller")
  filedDisputes       Dispute[]     @relation("FiledDisputes")
  savedAddresses      SavedAddress[]

  // Recommendation system
  interactions        UserInteraction[]
  trackingEnabled     Boolean   @default(true)

  // KYC relation
  verificationRequests VerificationRequest[]
}

// ─── Notifications ───────────────────────────────────

enum NotificationType {
  MESSAGE
  SYSTEM
  ORDER
  MODERATION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum EscrowStatus {
  // === Legacy statuses (still used by existing orders) ===
  FUNDS_HELD             // money deducted from buyer; sitting in escrow
  SHIPPED                // seller marked shipped; waiting on buyer confirmation
  COMPLETED              // buyer confirmed receipt; funds released to seller
  DISPUTED               // frozen by either party; awaiting admin resolution
  REFUNDED               // admin resolved in buyer's favour; money returned
  CANCELLED_BY_ADMIN     // admin closed dispute and overrode both parties
  CANCELLED              // buyer or seller cancelled before shipment; auto-refunded

  // === New checkout wizard statuses ===
  PENDING_CONFIRMATION   // seller hasn't confirmed yet
  DELIVERED              // buyer confirmed receipt (before payout release)

  // Escrow + Meetup
  MEETUP_SCHEDULED       // meetup arranged, funds held in escrow
  MEETUP_COMPLETED       // met up successfully, funds released

  // COD + Shipping
  AWAITING_SHIPMENT      // waiting for seller to ship (no money held)
  COD_SHIPPED            // shipped, awaiting COD collection
  COD_DELIVERED          // COD collected successfully

  // COD + Meetup
  MEETUP_ARRANGED        // meetup arranged, pay cash on meet
  MEETUP_CASH_COMPLETED  // met + paid cash successfully
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(SYSTEM)
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ──────────────────────────────────────

model Category {
  id     String  @id @default(cuid())
  slug   String  @unique
  nameTh String
  nameEn String
  emoji  String?
  items  Item[]
}

model Item {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  price       Float
  emoji       String?
  color       String?
  listingType ListingType   @default(SELL)
  condition   ItemCondition @default(GOOD)
  status      ItemStatus    @default(PENDING)
  rejectReason String?      @db.Text
  negotiable  Boolean       @default(false)
  shippable   Boolean       @default(false)
  location    String?
  contact     String?
  rating               Float     @default(0)
  viewCount            Int       @default(0)      // denormalized view counter for trending
  lastViewedAt         DateTime?                   // for "recently popular" signals
  scheduledForDeletionAt DateTime? // set when seller schedules deletion; null = not scheduled
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Checkout wizard: delivery/payment settings (per-item seller config)
  allowShipping     Boolean   @default(true)
  allowMeetup       Boolean   @default(true)
  allowCOD          Boolean   @default(true)
  shippingNote      String?   // e.g., "จัดส่งได้เฉพาะวันจันทร์-ศุกร์"

  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images        ItemImage[]
  wishlists     Wishlist[]
  conversations Conversation[]
  transactions  Transaction[]
  escrowOrders  EscrowOrder[]
  interactions  UserInteraction[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([listingType])
  @@index([createdAt])
  @@index([scheduledForDeletionAt])
}

model ItemImage {
  id     String  @id @default(cuid())
  url    String
  isMain Boolean @default(false)
  order  Int     @default(0)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemId   String
  item     Item      @relation(fields: [itemId], references: [id])
  members  User[]    @relation("ConversationMembers")
  messages Message[]

  @@index([itemId])
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  imageUrl  String?  // optional image attached to the message
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

// ─── Trust System ────────────────────────────────────

model Transaction {
  id        String            @id @default(cuid())
  status    TransactionStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  buyerId  String
  buyer    User   @relation("BuyerTransactions",  fields: [buyerId],  references: [id])
  sellerId String
  seller   User   @relation("SellerTransactions", fields: [sellerId], references: [id])

  review   Review?

  @@index([buyerId])
  @@index([sellerId])
  @@index([itemId])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1–5; enforced in application layer
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  transactionId String?      @unique   // one review per legacy Transaction
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  orderId String?      @unique   // one review per EscrowOrder
  order   EscrowOrder? @relation(fields: [orderId], references: [id])

  reviewerId String
  reviewer   User   @relation("ReviewsGiven",    fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([revieweeId])
  @@index([reviewerId])
}

// ─── Dispute System ──────────────────────────────────

enum DisputeStatus {
  OPEN
  RESOLVED
}

model Dispute {
  id             String        @id @default(cuid())
  reason         String        @db.Text
  evidenceImages String[]
  status         DisputeStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  orderId    String      @unique  // one dispute per order
  order      EscrowOrder @relation(fields: [orderId], references: [id])
  reporterId String
  reporter   User        @relation("FiledDisputes", fields: [reporterId], references: [id])

  @@index([status])
}

// ─── Escrow / Payment System ─────────────────────────

model EscrowOrder {
  id                 String       @id @default(cuid())
  amount             Float        // locked at purchase time; never mutated afterward
  status             EscrowStatus @default(FUNDS_HELD)
  // Cancellation
  cancelReason       String?      @db.Text
  cancelledBy        String?      // userId who cancelled
  cancelledAt        DateTime?
  // Shipping details (filled by seller in confirmShipment)
  shippedAt          DateTime?
  shippingMethod     String?      // "POST" | "KERRY" | "FLASH" | "MEETUP" | other
  trackingNumber     String?
  trackingCarrier    String?      // carrier name (e.g., "Kerry Express")
  shippingProofImage String?      // URL of receipt / parcel photo
  // Legacy dispute field kept for backward-compat; new disputes use Dispute model
  disputeReason      String?      @db.Text
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // ─── Checkout Wizard fields (nullable for legacy orders) ────────────
  deliveryMethod     DeliveryMethod?   // null = legacy (assumed SHIPPING)
  paymentMethod      PaymentMethod?    // null = legacy (assumed ESCROW)

  // Delivery details
  shippingAddress    Json?             // structured { recipientName, phone, ... }
  meetupLocation     String?
  meetupDateTime     DateTime?
  meetupNote         String?

  // Financial breakdown
  platformFee        Float     @default(0)
  shippingCost       Float     @default(0)
  totalAmount        Float?            // null for legacy (= amount)
  sellerPayout       Float?            // null for legacy (= amount)

  // Extended timestamps
  confirmedAt        DateTime?         // seller confirmed
  deliveredAt        DateTime?         // buyer confirmed delivery
  completedAt        DateTime?         // money released / transaction finished
  codConfirmedAt     DateTime?         // when COD payment was confirmed

  // Meetup proof of delivery
  handoverPhotoUrl      String?           // uploaded photo URL from /api/upload
  handoverSignature     String?  @db.Text  // base64 PNG of buyer's signature
  handoverConfirmedAt   DateTime?

  // Status tracking
  statusHistory      Json      @default("[]")
  expiresAt          DateTime?         // auto-cancel if seller doesn't confirm

  // Review references
  buyerReviewId      String?
  sellerReviewId     String?

  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  buyerId  String
  buyer    User   @relation("EscrowBuyer",  fields: [buyerId],  references: [id])
  sellerId String
  seller   User   @relation("EscrowSeller", fields: [sellerId], references: [id])

  dispute  Dispute?
  review   Review?

  @@index([buyerId])
  @@index([sellerId])
  @@index([itemId])
  @@index([status])
  @@index([status, createdAt])
}

// ─── Recommendation / Interaction System ─────────────

enum InteractionType {
  VIEW            // visited item detail
  SEARCH_CLICK    // clicked from search results
  WISHLIST_ADD    // added to wishlist
  CONTACT_SELLER  // opened chat with seller
  PURCHASE        // completed escrow purchase
}

enum PriceRange {
  BUDGET    // ฿0 – ฿100
  MID       // ฿101 – ฿500
  PREMIUM   // ฿501 – ฿2,000
  LUXURY    // ฿2,001+
}

model UserInteraction {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type       InteractionType @default(VIEW)
  category   String          // denormalized category slug — avoids JOIN on reads
  priceRange PriceRange?     // bucketed price at time of interaction
  source     String?         // "search" | "browse" | "recommendation" | "direct"
  createdAt  DateTime        @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category])
  @@index([itemId])
  @@index([createdAt])
  @@map("user_interactions")
}

// ─── Saved Addresses ─────────────────────────────────

model SavedAddress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String   @default("บ้าน")
  recipientName   String
  phone           String
  addressLine1    String
  addressLine2    String?
  district        String
  province        String
  postalCode      String
  note            String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("saved_addresses")
}

// ─── KYC Verification Requests ───────────────────────

model VerificationRequest {
  id                  String             @id @default(cuid())

  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Applicant info
  psuIdNumber         String
  psuIdType           PsuIdType
  facultyOrDepartment String?

  // Document uploads
  idCardImageUrl      String             // PSU ID card front
  idCardBackUrl       String?            // PSU ID card back (optional)

  // Face liveness captures
  selfieFrontUrl      String             // face — straight
  selfieLeftUrl       String?            // face — turned left
  selfieRightUrl      String?            // face — turned right
  selfieUpUrl         String?            // face — tilted up

  // Admin review
  status              VerificationStatus @default(PENDING)
  reviewedBy          String?
  reviewedAt          DateTime?
  rejectionReason     String?
  adminNote           String?

  // Metadata
  submittedAt         DateTime           @default(now())
  ipAddress           String?
  userAgent           String?

  @@index([userId])
  @@index([status, submittedAt])
  @@map("verification_requests")
}
